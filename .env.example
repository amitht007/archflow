# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=archflow
POSTGRES_PASSWORD=archflow_secret
POSTGRES_DB=archflow
POSTGRES_PORT=5432
DATABASE_URL=postgresql://archflow:archflow_secret@localhost:5432/archflow

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=archflow_redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:archflow_redis_secret@localhost:6379

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_before_production_use

# ─── pgAdmin (optional tools profile) ────────────────────────────────────────
PGADMIN_EMAIL=admin@archflow.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
