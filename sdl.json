    "svc_payment": {
      "displayName": "Payment Service",
      "type": "service",
      "owned": true,
      "team": "team_payments",
      "stack": {
        "language": "Java",
        "framework": "Spring Boot",
        "version": "17"
      },
      "repo": "github.com/org/payment-service",
      "env": [
        "DB_PAYMENTS_URL",
        "STRIPE_API_KEY",
        "KAFKA_BROKER"
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3004"
        },
        "prod": {
          "baseUrl": "http://payment.prod.internal"
        }
      },
      "endpoints": {
        "ep_process_payment": {
          "path": "/payments",
          "method": "POST",
          "protocol": "REST",
          "auth": "internal-service-token",
          "headers": {
            "x-service-token": {
              "type": "string",
              "description": "Internal S2S token generated by caller"
            }
          },
          "request": {
            "orderId": {
              "$ref": "#/types/t_uuid",
              "required": true
            },
            "amount": {
              "type": "number",
              "format": "decimal",
              "required": true
            },
            "currency": {
              "type": "string",
              "format": "iso4217",
              "required": true
            },
            "userId": {
              "$ref": "#/types/t_uuid",
              "required": true
            }
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_payment"
            },
            "402": {
              "error": {
                "type": "enum",
                "values": [
                  "INSUFFICIENT_FUNDS",
                  "CARD_DECLINED"
                ]
              }
            },
            "500": {
              "$ref": "#/types/t_error"
            }
          }
        },
        "ep_payments_status": {
          "path": "/payments/status",
          "method": "GET",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "request": {
            "paymentId": {
              "type": "string",
              "in": "query",
              "required": true,
              "$ref": "#/types/t_uuid"
            }
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_payment_status_response"
            }
          }
        }
      }
    },
    "svc_inventory": {
      "displayName": "Inventory Service",
      "type": "service",
      "owned": true,
      "team": "team_commerce",
      "stack": {
        "language": "Go",
        "framework": "Gin",
        "version": "1.21"
      },
      "repo": "github.com/org/inventory-service",
      "env": [
        "DB_INVENTORY_URL"
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3005"
        },
        "prod": {
          "baseUrl": "http://inventory.prod.internal"
        }
      },
      "endpoints": {
        "ep_check_stock": {
          "path": "/inventory.InventoryService/CheckStock",
          "method": "CheckStock",
          "protocol": "gRPC",
          "responses": {
            "OK": {
              "available": "boolean",
              "items": "array"
            },
            "NOT_FOUND": {
              "message": "string"
            },
            "UNAVAILABLE": {
              "message": "string"
            }
          },
          "proto": {
            "inline": true,
            "definition": {
              "package": "inventory",
              "service": "InventoryService",
              "rpc": "CheckStock",
              "request": {
                "items": {
                  "type": "repeated",
                  "message": "StockItem"
                }
              },
              "messages": {
                "StockItem": {
                  "product_id": {
                    "type": "string"
                  },
                  "quantity": {
                    "type": "int32"
                  }
                },
                "StockResponse": {
                  "available": {
                    "type": "bool"
                  },
                  "items": {
                    "type": "repeated",
                    "message": "StockItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "svc_notification": {
      "displayName": "Notification Service",
      "type": "service",
      "owned": true,
      "team": "team_comms",
      "stack": {
        "language": "Python",
        "framework": "FastAPI",
        "version": "3.12"
      },
      "repo": "github.com/org/notification-service",
      "env": [
        "KAFKA_BROKER",
        "SMTP_URL",
        "SMS_API_KEY"
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3006"
        },
        "prod": {
          "baseUrl": "http://notify.prod.internal"
        }
      },
      "endpoints": {
        "ep_health": {
          "path": "/health",
          "method": "GET",
          "protocol": "REST",
          "auth": "none",
          "responses": {
            "200": {
              "$ref": "#/types/t_health_response"
            }
          }
        },
        "ep_send_notification": {
          "path": "/notifications/send",
          "method": "POST",
          "protocol": "REST",
          "auth": "internal-service-token",
          "request": {
            "channel": {
              "type": "string",
              "enum": ["EMAIL", "SMS", "PUSH"]
            },
            "recipientId": {
              "type": "string",
              "format": "uuid"
            },
            "template": {
              "type": "string"
            },
