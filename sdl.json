  },
  "datastores": {
    "db_auth": {
      "displayName": "Auth DB",
      "type": "postgresql",
      "owned": true,
      "owner": "svc_auth",
      "entities": {
        "users": {
          "fields": {
            "id": {
              "type": "uuid",
              "primaryKey": true
            },
            "email": {
              "type": "string",
              "unique": true,
              "nullable": false
            },
            "password_hash": {
              "type": "string",
              "nullable": false
            },
            "role": {
              "type": "enum",
              "values": [
                "admin",
                "user",
                "guest"
              ]
            },
            "created_at": {
              "type": "timestamp",
              "default": "now()"
            },
            "updated_at": {
              "type": "timestamp",
              "default": "now()"
            }
          },
          "indexes": [
            {
              "name": "idx_users_email",
              "fields": [
                "email"
              ],
              "unique": true
            },
            {
              "name": "idx_users_role",
              "fields": [
                "role"
              ]
            }
          ],
          "implements": "#/types/t_user"
        },
        "refresh_tokens": {
          "fields": {
            "id": {
              "type": "uuid",
              "primaryKey": true
            },
            "user_id": {
              "type": "uuid",
              "foreignKey": "users.id"
            },
            "token_hash": {
              "type": "string",
              "nullable": false
            },
            "expires_at": {
              "type": "timestamp",
              "nullable": false
            },
            "revoked": {
              "type": "boolean",
              "default": false
            }
          },
          "indexes": [
            {
              "name": "idx_tokens_user",
              "fields": [
                "user_id"
              ]
            },
            {
              "name": "idx_tokens_hash",
              "fields": [
                "token_hash"
              ],
              "unique": true
            }
          ]
        }
      }
    },
    "db_orders": {
      "displayName": "Orders DB",
      "type": "postgresql",
      "owned": true,
      "owner": "svc_order",
      "entities": {
        "orders": {
          "fields": {
            "id": {
              "type": "uuid",
              "primaryKey": true
            },
            "user_id": {
              "type": "uuid",
              "nullable": false
            },
            "total": {
              "type": "decimal",
              "precision": 10,
              "scale": 2
            },
            "currency": {
              "type": "string",
              "length": 3
            },
            "status": {
              "type": "enum",
              "values": [
                "pending",
                "confirmed",
                "shipped",
                "delivered",
                "cancelled"
              ]
            },
            "created_at": {
              "type": "timestamp",
              "default": "now()"
            }
          },
          "indexes": [
            {
              "name": "idx_orders_user",
              "fields": [
                "user_id"
              ]
            },
            {
              "name": "idx_orders_status",
              "fields": [
                "status"
              ]
            },
            {
              "name": "idx_orders_created",
              "fields": [
                "created_at"
              ],
              "sort": "DESC"
            }
          ],
          "implements": "#/types/t_order"
        },
        "order_items": {
          "fields": {
            "id": {
              "type": "uuid",
              "primaryKey": true
            },
            "order_id": {
              "type": "uuid",
              "foreignKey": "orders.id"
            },
            "product_id": {
              "type": "uuid",
              "nullable": false
            },
            "quantity": {
              "type": "integer",
              "min": 1
            },
            "unit_price": {
              "type": "decimal",
              "precision": 10,
              "scale": 2
            }
          },
          "indexes": [
            {
              "name": "idx_items_order",
              "fields": [
                "order_id"
              ]
            }
          ]
        }
      }
    },
    "cache_sessions": {
      "displayName": "Session Cache",
      "type": "redis",
      "owned": true,
      "owner": "svc_auth",
      "keyPattern": "session:{userId}",
      "ttl": 3600,
      "value": {
        "$ref": "#/types/t_token"
      }
    },
    "queue_notifications": {
      "displayName": "Notification Queue",
      "type": "kafka",
      "owned": true,
      "owner": "svc_notification",
      "topics": {
        "user.registered": {
          "payload": {
            "$ref": "#/types/t_user"
          }
        },
        "order.confirmed": {
          "payload": {
            "$ref": "#/types/t_order"
          }
        },
        "payment.success": {
          "payload": {
            "$ref": "#/types/t_payment"
          }
        },
        "payment.failed": {
          "payload": {
            "$ref": "#/types/t_payment"
          }
        }
      }
    }
  },
  "contracts": {
    "c_client_to_cf": {
      "from": "svc_client",
      "to": "svc_cloudflare",
      "protocol": "HTTPS",
      "passthrough": true
    },
    "c_cf_to_gateway": {
      "from": "svc_cloudflare",
      "to": "svc_gateway",
      "protocol": "REST",
      "timeout": 10000,
      "passthrough": true
    },
    "c_login": {
      "from": "svc_gateway",
      "to": "svc_auth",
      "endpoint": "ep_login",
      "protocol": "REST",
      "pattern": "sync-request-response",
      "criticality": "critical",
      "timeout": 3000,
      "retry": {
        "attempts": 3,
        "backoff": "exponential"
      }
    },
    "c_get_products": {
      "from": "svc_gateway",
      "to": "svc_product",
      "endpoint": "ep_get_products",
      "protocol": "REST",
      "pattern": "sync-request-response",
      "criticality": "high",
      "timeout": 5000,
      "retry": {
        "attempts": 3,
        "backoff": "linear"
      }
    },
    "c_create_order": {
      "from": "svc_gateway",
      "to": "svc_order",
      "endpoint": "ep_create_order",
      "protocol": "REST",
      "pattern": "sync-request-response",
      "criticality": "critical",
      "timeout": 5000,
      "retry": {
        "attempts": 3,
        "backoff": "linear"
      }
    },
    "c_check_inventory": {
      "from": "svc_order",
      "to": "svc_inventory",
      "endpoint": "ep_check_stock",
      "protocol": "gRPC",
      "pattern": "sync-request-response",
      "criticality": "critical",
      "timeout": 2000,
      "retry": {
        "attempts": 2,
        "backoff": "fixed"
      }
    },
    "c_process_payment": {
      "from": "svc_order",
      "to": "svc_payment",
      "endpoint": "ep_process_payment",
      "protocol": "REST",
      "pattern": "sync-request-response",
      "criticality": "critical",
      "timeout": 10000,
      "retry": {
        "attempts": 0
      }
    },
    "c_stripe_charge": {
      "from": "svc_payment",
      "to": "svc_stripe",
      "endpoint": "ep_stripe_charge",
      "protocol": "REST",
      "pattern": "sync-request-response",
      "criticality": "critical",
      "timeout": 15000,
      "retry": {
        "attempts": 1
      }
    },
    "c_gateway_to_notification": {
      "from": "svc_gateway",
      "to": "svc_notification",
      "endpoint": "ep_send_notification",
      "protocol": "REST",
      "pattern": "fire-and-forget",
      "criticality": "medium",
      "timeout": 3000,
      "retry": {
        "attempts": 2,
        "backoff": "exponential"
      }
    },
    "c_auth_to_notification": {
      "from": "svc_auth",
      "to": "svc_notification",
      "endpoint": "ep_send_notification",
      "protocol": "REST",
      "pattern": "fire-and-forget",
      "criticality": "medium",
      "timeout": 2000,
      "retry": {
        "attempts": 3,
        "backoff": "linear"
      }
    },
    "c_order_to_notification": {
      "from": "svc_order",
      "to": "svc_notification",
      "endpoint": "ep_send_notification",
      "protocol": "REST",
      "pattern": "fire-and-forget",
      "criticality": "low",
      "timeout": 2000,
      "retry": {
        "attempts": 2
      }
    },
    "c_payment_to_notification": {
      "from": "svc_payment",
      "to": "svc_notification",
      "endpoint": "ep_send_notification",
      "protocol": "REST",
      "pattern": "fire-and-forget",
      "criticality": "low",
      "timeout": 2000,
      "retry": {
        "attempts": 2
      }
    },
    "c_publish_order_confirmed": {
      "from": "svc_order",
      "to": "queue_notifications",
      "protocol": "kafka",
      "pattern": "fire-and-forget",
      "topic": "order.confirmed.v1",
      "criticality": "medium"
    },
    "c_publish_payment_result": {
      "from": "svc_payment",
      "to": "queue_notifications",
      "protocol": "kafka",
      "pattern": "fire-and-forget",
      "topics": [
        "payment.success.v1",
        "payment.failed.v1"
      ],
      "criticality": "medium"
    },
    "c_send_notification": {
      "from": "queue_notifications",
      "to": "svc_notification",
      "protocol": "kafka",
      "pattern": "subscribe-and-consume",
      "topics": [
        "order.confirmed.v1",
        "payment.success.v1",
        "payment.failed.v1"
      ],
      "criticality": "low"
    }
  },
  "flows": {
    "flow_user_login": {
      "displayName": "User Login",
      "description": "Complete login journey from client submitting credentials to receiving JWT token",
      "trigger": "User submits login form",
      "tasks": [
        {
          "task": 1,
          "type": "network",
          "ref": "c_client_to_cf",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 2,
          "type": "network",
          "ref": "c_cf_to_gateway",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 3,
          "type": "network",
          "ref": "c_login",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 4,
          "type": "compute",
          "owner": "svc_auth",
          "description": "Verify password hash against stored bcrypt hash in db_auth.users",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 5,
          "type": "db",
          "owner": "svc_auth",
          "description": "Generate JWT access token and refresh token. Store refresh token hash in db_auth.refresh_tokens. Cache session in cache_sessions.",
          "onSuccess": "next",
          "onFailure": "abort"
        }
      ]
    },
    "flow_checkout": {
      "displayName": "Checkout",
      "description": "Complete purchase flow from cart submission to order confirmation and payment",
      "trigger": "User clicks Place Order",
      "tasks": [
        {
          "task": 1,
          "type": "network",
          "ref": "c_create_order",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 2,
          "type": "network",
          "ref": "c_check_inventory",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 3,
          "type": "compute",
          "owner": "svc_order",
          "description": "Reserve inventory. Mark items as held pending payment confirmation.",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 4,
          "type": "network",
          "ref": "c_process_payment",
          "onSuccess": "next",
          "onFailure": "compensate",
          "compensate": {
            "type": "logic",
            "owner": "svc_order",
            "description": "Release inventory hold. Set order status to cancelled."
          }
        },
        {
          "task": 5,
          "type": "network",
          "ref": "c_stripe_charge",
          "onSuccess": "next",
          "onFailure": "compensate",
          "compensate": {
            "type": "logic",
            "owner": "svc_payment",
            "description": "Void payment intent. Notify order service of failure."
          }
        },
        {
          "task": 6,
          "type": "db",
          "owner": "svc_order",
          "description": "Set order status to confirmed. Write final record to db_orders.",
          "onSuccess": "next",
          "onFailure": "abort"
        },
        {
          "task": 7,
          "type": "network",
          "ref": "c_publish_order_confirmed",
          "onSuccess": "next",
          "onFailure": "continue"
        }
      ]
    }
  }
}