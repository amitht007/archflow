      "environments": {
        "dev": {
          "baseUrl": "https://api.stripe.com"
        },
        "prod": {
          "baseUrl": "https://api.stripe.com"
        }
      },
      "endpoints": {
        "ep_stripe_charge": {
          "path": "/v1/charges",
          "method": "POST",
