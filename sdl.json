{
  "types": {
    "t_uuid": {
      "type": "string",
      "format": "uuid"
    },
    "t_timestamp": {
      "type": "string",
      "format": "datetime-iso8601"
    },
    "t_error": {
      "type": "object",
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "traceId": {
          "type": "string",
          "format": "uuid"
        }
      }
    },
    "t_pagination": {
      "type": "object",
      "properties": {
        "page": {
          "type": "integer",
          "min": 1
        },
        "pageSize": {
          "type": "integer",
          "min": 1,
          "max": 100
        },
        "total": {
          "type": "integer"
        }
      }
    },
    "t_user": {
      "type": "object",
      "properties": {
        "userId": {
          "$ref": "#/types/t_uuid"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "enum",
          "values": [
            "admin",
            "user",
            "guest"
          ]
        },
        "createdAt": {
          "$ref": "#/types/t_timestamp"
        }
      }
    },
    "t_token": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string",
          "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
        },
        "refreshToken": {
          "type": "string",
          "value": "d8f9q2pZ..."
        },
        "expiresAt": {
          "$ref": "#/types/t_timestamp",
          "value": "2026-04-10T12:00:00Z"
        }
      }
    },
    "t_product": {
      "type": "object",
      "properties": {
        "productId": {
          "$ref": "#/types/t_uuid",
          "value": "9b1deb4d-3b7d-4bad-9bdd-2b0d7b3dcb6d"
        },
        "name": {
          "type": "string",
          "value": "Wireless Headphones"
        },
        "price": {
          "type": "number",
          "format": "decimal",
          "value": 99.99
        },
        "currency": {
          "type": "string",
          "format": "iso4217",
          "value": "USD"
        },
        "stock": {
          "type": "integer",
          "min": 0,
          "value": 42
        },
        "category": {
          "type": "string",
          "value": "electronics"
        }
      }
    },
    "t_order": {
      "type": "object",
      "properties": {
        "orderId": {
          "$ref": "#/types/t_uuid"
        },
        "userId": {
          "$ref": "#/types/t_uuid"
        },
        "items": {
          "type": "array",
          "items": "$ref:t_order_item"
        },
        "total": {
          "type": "number",
          "format": "decimal"
        },
        "currency": {
          "type": "string",
          "format": "iso4217"
        },
        "status": {
          "type": "enum",
          "values": [
            "pending",
            "confirmed",
            "shipped",
            "delivered",
            "cancelled"
          ]
        },
        "createdAt": {
          "$ref": "#/types/t_timestamp"
        }
      }
    },
    "t_order_item": {
      "type": "object",
      "properties": {
        "productId": {
          "$ref": "#/types/t_uuid"
        },
        "quantity": {
          "type": "integer",
          "min": 1
        },
        "unitPrice": {
          "type": "number",
          "format": "decimal"
        }
      }
    },
    "t_payment": {
      "type": "object",
      "properties": {
        "paymentId": {
          "$ref": "#/types/t_uuid"
        },
        "orderId": {
          "$ref": "#/types/t_uuid"
        },
        "amount": {
          "type": "number",
          "format": "decimal"
        },
        "currency": {
          "type": "string",
          "format": "iso4217"
        },
        "status": {
          "type": "enum",
          "values": [
            "pending",
            "success",
            "failed",
            "refunded"
          ]
        },
        "provider": {
          "type": "string"
        },
        "processedAt": {
          "$ref": "#/types/t_timestamp"
        }
      }
    },
    "t_notification": {
      "type": "object",
      "properties": {
        "notificationId": {
          "$ref": "#/types/t_uuid"
        },
        "userId": {
          "$ref": "#/types/t_uuid"
        },
        "channel": {
          "type": "enum",
          "values": [
            "email",
            "sms",
            "push"
          ]
        },
        "template": {
          "type": "string"
        },
        "payload": {
          "type": "object"
        },
        "sentAt": {
          "$ref": "#/types/t_timestamp"
        }
      }
    },
    "t_registration_request": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "password": {
          "type": "string",
          "minLength": 8
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "role": {
          "type": "enum",
          "values": [
            "user",
            "guest"
          ],
          "default": "user"
        }
      }
    },
    "t_search_params": {
      "type": "object",
      "properties": {
        "q": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "required": false
        },
        "page": {
          "type": "integer",
          "min": 1,
          "default": 1
        },
        "pageSize": {
          "type": "integer",
          "min": 1,
          "max": 100,
          "default": 20
        },
        "sortBy": {
          "type": "enum",
          "values": [
            "price_asc",
            "price_desc",
            "name_asc",
            "newest"
          ],
          "default": "newest"
        }
      }
    },
    "t_search_result": {
      "type": "object",
      "properties": {
        "products": {
          "type": "array",
          "items": "$ref:t_product"
        },
        "meta": {
          "$ref": "#/types/t_pagination"
        },
        "query": {
          "type": "string"
        }
      }
    },
    "t_category_list": {
      "type": "object",
      "properties": {
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "t_pricing_request": {
      "type": "object",
      "properties": {
        "productIds": {
          "type": "array",
          "items": "$ref:t_uuid",
          "minItems": 1,
          "maxItems": 100
        },
        "currency": {
          "type": "string",
          "format": "iso4217",
          "default": "USD"
        }
      }
    },
    "t_pricing_response": {
      "type": "object",
      "properties": {
        "prices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": {
                "$ref": "#/types/t_uuid"
              },
              "price": {
                "type": "number",
                "format": "decimal"
              },
              "currency": {
                "type": "string",
                "format": "iso4217"
              },
              "discount": {
                "type": "number",
                "format": "decimal",
                "nullable": true
              },
              "finalPrice": {
                "type": "number",
                "format": "decimal"
              }
            }
          }
        }
      }
    },
    "t_inventory_item": {
      "type": "object",
      "properties": {
        "productId": {
          "$ref": "#/types/t_uuid"
        },
        "stock": {
          "type": "integer",
          "min": 0
        },
        "warehouse": {
          "type": "string"
        },
        "reserved": {
          "type": "integer",
          "min": 0
        },
        "available": {
          "type": "integer",
          "min": 0
        }
      }
    },
    "t_inventory_response": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": "$ref:t_inventory_item"
        },
        "meta": {
          "$ref": "#/types/t_pagination"
        }
      }
    },
    "t_checkout_request": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": "$ref:t_order_item"
        },
        "shippingAddress": {
          "type": "object",
          "properties": {
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "nullable": true
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string"
            },
            "postalCode": {
              "type": "string"
            },
            "country": {
              "type": "string",
              "format": "iso3166-alpha2"
            }
          }
        },
        "paymentMethod": {
          "type": "enum",
          "values": [
            "card",
            "wallet",
            "upi"
          ]
        },
        "couponCode": {
          "type": "string",
          "nullable": true
        }
      }
    },
    "t_checkout_response": {
      "type": "object",
      "properties": {
        "orderId": {
          "$ref": "#/types/t_uuid"
        },
        "order": {
          "$ref": "#/types/t_order"
        },
        "paymentIntent": {
          "type": "object",
          "properties": {
            "clientSecret": {
              "type": "string"
            },
            "amount": {
              "type": "number",
              "format": "decimal"
            },
            "currency": {
              "type": "string",
              "format": "iso4217"
            }
          }
        },
        "estimatedDelivery": {
          "$ref": "#/types/t_timestamp"
        }
      }
    },
    "t_order_history_response": {
      "type": "object",
      "properties": {
        "orders": {
          "type": "array",
          "items": "$ref:t_order"
        },
        "meta": {
          "$ref": "#/types/t_pagination"
        }
      }
    },
    "t_shipping_status": {
      "type": "object",
      "properties": {
        "orderId": {
          "$ref": "#/types/t_uuid"
        },
        "status": {
          "type": "enum",
          "values": [
            "processing",
            "shipped",
            "in_transit",
            "out_for_delivery",
            "delivered",
            "returned"
          ]
        },
        "carrier": {
          "type": "string",
          "nullable": true
        },
        "trackingNumber": {
          "type": "string",
          "nullable": true
        },
        "estimatedDelivery": {
          "$ref": "#/types/t_timestamp",
          "nullable": true
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {
                "$ref": "#/types/t_timestamp"
              },
              "location": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "t_payment_status_response": {
      "type": "object",
      "properties": {
        "paymentId": {
          "$ref": "#/types/t_uuid"
        },
        "orderId": {
          "$ref": "#/types/t_uuid"
        },
        "status": {
          "type": "enum",
          "values": [
            "pending",
            "success",
            "failed",
            "refunded"
          ]
        },
        "amount": {
          "type": "number",
          "format": "decimal"
        },
        "currency": {
          "type": "string",
          "format": "iso4217"
        },
        "provider": {
          "type": "string"
        },
        "providerTransactionId": {
          "type": "string",
          "nullable": true
        },
        "processedAt": {
          "$ref": "#/types/t_timestamp",
          "nullable": true
        },
        "failureReason": {
          "type": "string",
          "nullable": true
        }
      }
    },
    "t_health_response": {
      "type": "object",
      "properties": {
        "status": {
          "type": "enum",
          "values": [
            "healthy",
            "degraded",
            "unhealthy"
          ]
        },
        "uptime": {
          "type": "integer",
          "description": "Uptime in seconds"
        },
        "timestamp": {
          "$ref": "#/types/t_timestamp"
        },
        "checks": {
          "type": "object",
          "properties": {
            "database": {
              "type": "string",
              "enum": [
                "ok",
                "error"
              ]
            },
            "kafka": {
              "type": "string",
              "enum": [
                "ok",
                "error"
              ]
            }
          }
        }
      }
    }
  },
  "services": {
    "svc_client": {
      "displayName": "Web Client UI",
      "type": "frontend",
      "owned": true,
      "stack": {
        "language": "TypeScript",
        "framework": "React"
      },
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:8080"
        },
        "prod": {
          "baseUrl": "https://myapp.com"
        }
      }
    },
    "svc_cloudflare": {
      "displayName": "Cloudflare",
      "type": "external",
      "owned": false,
      "vendor": "Cloudflare",
      "description": "Edge network. TLS termination. DDoS protection. Rate limiting.",
      "environments": {
        "dev": {
          "baseUrl": "https://dev.myapp.com"
        },
        "uat": {
          "baseUrl": "https://uat.myapp.com"
        },
        "stage": {
          "baseUrl": "https://stage.myapp.com"
        },
        "prod": {
          "baseUrl": "https://myapp.com"
        }
      },
      "endpoints": {}
    },
    "svc_gateway": {
      "displayName": "API Gateway",
      "type": "gateway",
      "owned": true,
      "team": "team_platform",
      "stack": {
        "language": "Node.js",
        "framework": "Express",
        "version": "20"
      },
      "repo": "github.com/org/api-gateway",
      "middleware": [
        "rate-limit",
        "jwt-verify",
        "request-decrypt",
        "response-encrypt"
      ],
      "routes": [
        {
          "publicPath": "/api/v1/auth/*",
          "targetService": "svc_auth",
          "stripPrefix": false
        },
        {
          "publicPath": "/api/v1/products/*",
          "targetService": "svc_product",
          "stripPrefix": true
        },
        {
          "publicPath": "/api/v1/orders/*",
          "targetService": "svc_order",
          "stripPrefix": true
        },
        {
          "publicPath": "/api/v1/payments/*",
          "targetService": "svc_payment",
          "stripPrefix": true
        },
        {
          "publicPath": "/api/v1/notifications/*",
          "targetService": "svc_notification",
          "stripPrefix": true
        }
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3000"
        },
        "uat": {
          "baseUrl": "http://gateway.uat.internal"
        },
        "stage": {
          "baseUrl": "http://gateway.stage.internal"
        },
        "prod": {
          "baseUrl": "http://gateway.prod.internal"
        }
      }
    },
    "svc_auth": {
      "displayName": "Auth Service",
      "type": "service",
      "owned": true,
      "team": "team_identity",
      "stack": {
        "language": "Go",
        "framework": "Gin",
        "version": "1.21"
      },
      "repo": "github.com/org/auth-service",
      "env": [
        "DB_AUTH_URL",
        "JWT_SECRET",
        "REDIS_HOST"
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3001"
        },
        "uat": {
          "baseUrl": "http://auth.uat.internal"
        },
        "stage": {
          "baseUrl": "http://auth.stage.internal"
        },
        "prod": {
          "baseUrl": "http://auth.prod.internal"
        }
      },
      "endpoints": {
        "ep_register": {
          "path": "/auth/v1/register",
          "method": "POST",
          "protocol": "REST",
          "auth": "none",
          "request": {
            "$ref": "#/types/t_registration_request"
          },
          "responses": {
            "201": {
              "$ref": "#/types/t_user"
            },
            "400": {
              "$ref": "#/types/t_error"
            }
          }
        },
        "ep_logout": {
          "path": "/auth/v1/logout",
          "method": "POST",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "responses": {
            "200": {
              "description": "Successfully logged out"
            }
          }
        },
        "ep_token_refresh": {
          "path": "/auth/v1/token/refresh",
          "method": "POST",
          "protocol": "REST",
          "auth": "none",
          "request": {
            "refreshToken": {
              "type": "string",
              "example": "d8f9q2pZ...",
              "required": true
            }
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_token"
            },
            "401": {
              "$ref": "#/types/t_error"
            }
          }
        },
        "ep_me": {
          "path": "/auth/v1/me",
          "method": "GET",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "responses": {
            "200": {
              "$ref": "#/types/t_user"
            }
          }
        },
        "ep_login": {
          "path": "/auth/login",
          "method": "POST",
          "protocol": "REST",
          "auth": "none",
          "request": {
            "email": {
              "type": "string",
              "format": "email",
              "required": true,
              "value": "email@gmail.com"
            },
            "password": {
              "type": "string",
              "min": 8,
              "required": true,
              "value": "password"
            }
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_token"
            },
            "401": {
              "error": {
                "type": "enum",
                "values": [
                  "INVALID_CREDENTIALS",
                  "ACCOUNT_LOCKED"
                ]
              }
            },
            "429": {
              "error": "string",
              "retryAfter": "integer"
            },
            "500": {
              "$ref": "#/types/t_error"
            }
          }
        }
      }
    },
    "svc_product": {
      "displayName": "Product Service",
      "type": "service",
      "owned": true,
      "team": "team_commerce",
      "stack": {
        "language": "Node.js",
        "framework": "NestJS",
        "version": "20"
      },
      "repo": "github.com/org/product-service",
      "env": [
        "DB_PRODUCTS_URL",
        "REDIS_HOST"
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3002"
        },
        "prod": {
          "baseUrl": "http://product.prod.internal"
        }
      },
      "endpoints": {
        "ep_get_products": {
          "path": "/products",
          "method": "GET",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "injectedContext": [
            {
              "header": "x-user-id",
              "type": "uuid",
              "description": "Injected by API Gateway after JWT verification"
            }
          ],
          "request": {
            "category": {
              "type": "string",
              "required": false,
              "value": "electronics"
            },
            "page": {
              "type": "integer",
              "required": false,
              "value": 1
            },
            "pageSize": {
              "type": "integer",
              "required": false,
              "value": 20
            }
          },
          "responses": {
            "200": {
              "products": {
                "type": "array",
                "items": {
                  "$ref": "#/types/t_product"
                }
              },
              "meta": {
                "$ref": "#/types/t_pagination"
              }
            },
            "401": {
              "$ref": "#/types/t_error"
            },
            "500": {
              "$ref": "#/types/t_error"
            }
          }
        },
        "ep_products_search": {
          "path": "/products/search",
          "method": "GET",
          "protocol": "REST",
          "auth": "none",
          "request": {
            "$ref": "#/types/t_search_params"
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_search_result"
            }
          }
        },
        "ep_products_categories": {
          "path": "/products/categories",
          "method": "GET",
          "protocol": "REST",
          "auth": "none",
          "responses": {
            "200": {
              "$ref": "#/types/t_category_list"
            }
          }
        },
        "ep_products_pricing": {
          "path": "/products/pricing",
          "method": "POST",
          "protocol": "REST",
          "auth": "none",
          "request": {
            "$ref": "#/types/t_pricing_request"
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_pricing_response"
            }
          }
        },
        "ep_products_inventory": {
          "path": "/products/inventory",
          "method": "GET",
          "protocol": "REST",
          "auth": "none",
          "responses": {
            "200": {
              "$ref": "#/types/t_inventory_response"
            }
          }
        }
      }
    },
    "svc_order": {
      "displayName": "Order Service",
      "type": "service",
      "owned": true,
      "team": "team_commerce",
      "stack": {
        "language": "Node.js",
        "framework": "NestJS",
        "version": "20"
      },
      "repo": "github.com/org/order-service",
      "env": [
        "DB_ORDERS_URL",
        "KAFKA_BROKER"
      ],
      "environments": {
        "dev": {
          "baseUrl": "http://localhost:3003"
        },
        "prod": {
          "baseUrl": "http://order.prod.internal"
        }
      },
      "endpoints": {
        "ep_create_order": {
          "path": "/orders",
          "method": "POST",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "injectedContext": [
            {
              "header": "x-user-id",
              "type": "uuid",
              "description": "Injected by API Gateway after JWT verification"
            }
          ],
          "request": {
            "items": {
              "type": "array",
              "items": {
                "$ref": "#/types/t_order_item"
              },
              "required": true
            }
          },
          "responses": {
            "201": {
              "$ref": "#/types/t_order"
            },
            "400": {
              "error": {
                "type": "enum",
                "values": [
                  "INVALID_ITEMS",
                  "OUT_OF_STOCK"
                ]
              }
            },
            "401": {
              "$ref": "#/types/t_error"
            },
            "500": {
              "$ref": "#/types/t_error"
            }
          }
        },
        "ep_checkout": {
          "path": "/orders/checkout",
          "method": "POST",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "request": {
            "$ref": "#/types/t_checkout_request"
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_checkout_response"
            }
          }
        },
        "ep_orders_history": {
          "path": "/orders/history",
          "method": "GET",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "responses": {
            "200": {
              "$ref": "#/types/t_order_history_response"
            }
          }
        },
        "ep_orders_details": {
          "path": "/orders/details",
          "method": "GET",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "request": {
            "orderId": {
              "type": "string",
              "in": "path",
              "required": true,
              "$ref": "#/types/t_uuid"
            }
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_order"
            }
          }
        },
        "ep_orders_track": {
          "path": "/orders/track",
          "method": "GET",
          "protocol": "REST",
          "auth": "bearer-jwt",
          "request": {
            "orderId": {
              "type": "string",
              "in": "query",
              "required": true,
              "$ref": "#/types/t_uuid"
            }
          },
          "responses": {
            "200": {
              "$ref": "#/types/t_shipping_status"
            }
          }
        },
        "ep_orders_cancel": {
          "path": "/orders/cancel",
          "method": "POST",
          "protocol": "REST",
