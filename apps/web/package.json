    "reactflow": "^11.11.3",
    "tailwindcss-animate": "^1.0.7",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.14",
    "zod": "^3.23.4",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
