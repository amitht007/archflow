{
  "name": "@archflow/web",
  "version": "0.1.0",
  "private": true,
  "description": "ArchFlow Web — Vite + React + TypeScript",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
